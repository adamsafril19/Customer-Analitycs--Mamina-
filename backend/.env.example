# Flask
FLASK_ENV=production
FLASK_APP=app:create_app
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False

# JWT
JWT_SECRET_KEY=your-jwt-secret-here-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/churn_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ML Models
MODEL_PATH=/app/models/churn_model.pkl
VECTORIZER_PATH=/app/models/vectorizer.pkl
FEATURE_META_PATH=/app/models/features.json
SHAP_EXPLAINER_PATH=/app/models/shap_explainer.pkl

# Model Config
MODEL_VERSION=v1.0.0
ENABLE_SHAP=true
SHAP_BACKGROUND_MODE=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# Security - Phone Hash Salt
PHONE_HASH_SALT=your-phone-hash-salt-here

# Admin Credentials (for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_EMAIL=admin@mamina.com
